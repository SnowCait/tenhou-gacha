{
	"name": "mahjong-gacha",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"predev": "npm run build:wasm",
		"build": "vite build",
		"prebuild": "npm run build:wasm",
		"build:wasm": "wasm-pack build wasm --target web --out-dir ../src/lib/wasm/pkg",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e && npm run test:e2e:base",
		"test:e2e": "playwright install && playwright test",
		"test:e2e:base": "playwright install && playwright test --config playwright.base.config.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@inlang/plugin-m-function-matcher": "^2.2.9",
		"@inlang/plugin-message-format": "^4.4.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"wasm-pack": "^0.15.0"
	},
	"dependencies": {
		"canvas-confetti": "^1.9.4"
	}
}
